generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String        @id @default(uuid()) @db.Uuid
  clerkUserId        String        @unique
  username           String?
  avatarUrl          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  achievements       Achievement[]
  blogs              Blog[]
  replies            Reply[]
  verificationsGiven Reply[]       @relation("VerifiedBy")
  threads            Thread[]
  userRoles          UserRole[]
  stats              UserStats?
  votes              Vote[]

  @@map("users")
}

model Blog {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  slug      String   @unique
  content   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String   @db.Uuid
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("blogs")
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}

model Role {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @unique
  createdAt DateTime   @default(now())
  users     UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Thread {
  id           String      @id @default(uuid()) @db.Uuid
  title        String
  content      String
  pinned       Boolean     @default(false)
  viewsCount   Int         @default(0)
  repliesCount Int         @default(0)
  votesCount   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  authorId     String      @db.Uuid
  slug         String      @unique
  replies      Reply[]
  tags         ThreadTag[]
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@map("threads")
}

model Tag {
  id        String      @id @default(uuid()) @db.Uuid
  slug      String      @unique
  label     String
  createdAt DateTime    @default(now())
  threads   ThreadTag[]

  @@map("tags")
}

model ThreadTag {
  threadId String @db.Uuid
  tagId    String @db.Uuid
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([threadId, tagId])
  @@map("thread_tags")
}

model Reply {
  id                 String             @id @default(uuid()) @db.Uuid
  content            String
  pinned             Boolean            @default(false)
  votesCount         Int                @default(0)
  replyType          ReplyType          @default(DISCUSSION)
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  threadId           String             @db.Uuid
  parentId           String?            @db.Uuid
  authorId           String             @db.Uuid
  verifiedById       String?            @db.Uuid
  author             User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent             Reply?             @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: Cascade)
  children           Reply[]            @relation("ReplyToReply")
  thread             Thread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  verifiedBy         User?              @relation("VerifiedBy", fields: [verifiedById], references: [id])
  votes              Vote[]

  @@map("replies")
}

model Vote {
  id        String   @id @default(uuid()) @db.Uuid
  value     Int
  createdAt DateTime @default(now())
  userId    String   @db.Uuid
  threadId  String?  @db.Uuid
  replyId   String?  @db.Uuid
  reply     Reply?   @relation(fields: [replyId], references: [id], onDelete: Cascade)
  thread    Thread?  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@unique([userId, replyId])
  @@map("votes")
}

model UserStats {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  clarityScore      Float    @default(0)
  totalAnswers      Int      @default(0)
  verifiedCorrect   Int      @default(0)
  verifiedIncorrect Int      @default(0)
  totalDiscussions  Int      @default(0)
  totalThreads      Int      @default(0)
  totalUpvotes      Int      @default(0)
  totalDownvotes    Int      @default(0)
  answerStreak      Int      @default(0)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Achievement {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  slug     String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@map("achievements")
}

enum VoteTargetType {
  THREAD
  REPLY
}

enum ReplyType {
  ANSWER
  DISCUSSION
}

enum VerificationStatus {
  PENDING
  CORRECT
  INCORRECT
  DISPUTED
}
